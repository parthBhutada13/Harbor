# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/harbor_finance?retryWrites=true&w=majority

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64_character_random_hex_secret_here

# Server port
PORT=5000

# Set to 'production' on your deployment platform
NODE_ENV=development

ALLOWED_ORIGIN=https://harbor-nu-wine.vercel.app/
